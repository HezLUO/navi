  "description": "Navi helps non-expert users understand, supervise, and steer expert agents with maps, challenge, pause, stage/vision, and coordination guidance.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/HezLUO/navi.git"
  },
  "bugs": {
    "url": "https://github.com/HezLUO/navi/issues"
  },
  "homepage": "https://github.com/HezLUO/navi#readme",
  "bin": {
    "navi": "src/cli/navi-bin.mjs"
  },
  "scripts": {
    "navi": "./src/cli/navi-bin.mjs",
    "build:plugin-init": "node scripts/build-plugin-init.mjs",
    "check:plugin-init": "node scripts/build-plugin-init.mjs --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "verify:plugin-package": "node scripts/verify-plugin-package.mjs"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.1",
